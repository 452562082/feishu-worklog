<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.xiaolong.feishu-worklog</string>

    <!-- 触发方式：用户登录 / 开盖唤醒 / agent 加载（含 reload）时各跑一次
         配合 --catch-up，已生成的日子会快速退出。手动触发也可：
           launchctl kickstart -k gui/$(id -u)/com.xiaolong.feishu-worklog -->
    <key>RunAtLoad</key>
    <true/>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/xiaolong/go/src/feishu-worklog/.venv/bin/python</string>
        <string>-m</string>
        <string>scripts.run_daily</string>
        <string>--catch-up</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/xiaolong/go/src/feishu-worklog</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/xiaolong/.local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <!-- 用户登录态相关：让 claude CLI 能读 keychain -->
        <key>HOME</key>
        <string>/Users/xiaolong</string>
    </dict>

    <!-- 日志（运行输出/错误） -->
    <key>StandardOutPath</key>
    <string>/Users/xiaolong/go/src/feishu-worklog/data/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/xiaolong/go/src/feishu-worklog/data/launchd.err.log</string>

    <!-- 防止僵尸：超过 10 分钟没结束就 kill -->
    <key>ExitTimeOut</key>
    <integer>600</integer>

    <!-- 同一个任务实例只允许 1 个并发 -->
    <key>ThrottleInterval</key>
    <integer>60</integer>
</dict>
</plist>
